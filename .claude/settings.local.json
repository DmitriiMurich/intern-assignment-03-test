{
  "permissions": {
    "allow": [
      "Bash(docker --version)",
      "Bash(docker compose *)",
      "Bash(npm --version)",
      "PowerShell(Get-Command docker -ErrorAction SilentlyContinue)",
      "PowerShell(wsl --status 2>&1)",
      "PowerShell(wsl -l -v 2>&1)",
      "Bash(wsl -d Ubuntu -- bash -c \"docker --version 2>/dev/null || echo 'NOT INSTALLED'\")",
      "Bash(wsl -d Ubuntu -- bash -c \"sudo apt-get update -qq && sudo apt-get install -y -qq ca-certificates curl gnupg lsb-release 2>&1 | tail -5\")",
      "Bash(grep -E \"\\\\.\\(ts|java|kt|py|js|tsx|jsx\\)$\")",
      "Bash(mkdir -p .claude/commands)",
      "Bash(cp .claude/agents/write-tests.md .claude/commands/write-tests.md)",
      "Bash(cp .claude/agents/run-tests.md .claude/commands/run-tests.md)",
      "Bash(cp .claude/agents/run-project-and-tests.md .claude/commands/run-project-and-tests.md)",
      "Bash(curl -sf http://localhost:8080/health)",
      "Bash(wsl -d Ubuntu -- bash -c \"docker --version 2>/dev/null && echo 'DOCKER_OK' || echo 'NO_DOCKER'\")",
      "Bash(wsl -d Ubuntu -- bash -c ' *)"
    ]
  }
}
